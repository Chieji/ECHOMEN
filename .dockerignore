# ECHOMEN Docker Ignore File
# Excludes unnecessary files from Docker build context to reduce image size and attack surface

# =============================================================================
# Dependencies (installed during build)
# =============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# =============================================================================
# Version Control
# =============================================================================
.git/
.gitignore
.gitattributes
.gitmodules

# =============================================================================
# IDE and Editor Files
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# =============================================================================
# Logs and Temporary Files
# =============================================================================
*.log
logs/
tmp/
temp/
.cache/

# =============================================================================
# Test Files (not needed in production)
# =============================================================================
test/
tests/
__tests__/
*.test.js
*.test.ts
*.spec.js
*.spec.ts
coverage/
.nyc_output/
jest.config.*
mocha.opts
vitest.config.*

# =============================================================================
# Documentation (not needed in container)
# =============================================================================
*.md
!README.md
docs/
documentation/

# =============================================================================
# Build Artifacts (generated during build)
# =============================================================================
dist/
build/
out/
*.tsbuildinfo

# =============================================================================
# Environment Files (use Docker secrets or env_file instead)
# =============================================================================
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production

# =============================================================================
# Docker Files (not needed inside container)
# =============================================================================
Dockerfile*
docker-compose*.yml
.dockerignore
docker-entrypoint.sh

# =============================================================================
# CI/CD Configuration
# =============================================================================
.github/
.gitlab-ci.yml
.travis.yml
Jenkinsfile
circle.yml
appveyor.yml

# =============================================================================
# ECHOMEN Specific Exclusions
# =============================================================================
# Development tools and scripts
scripts/
.devcontainer/
.plans/
.reviews/
architecture/

# Large binary files and downloads
*.deb
*.tar.gz
*.zip
*.exe
*.dll
*.so

# Windows-specific files
NTUSER.DAT*
ntuser.*
*.bat
*.cmd

# Frontend source (backend doesn't need it)
components/
hooks/
lib/
services/
types/
App.tsx
index.html
index.tsx
types.ts
vite.config.ts
tsconfig.json

# Brain and outputs directories
brain/
outputs/

# Configuration files not needed in backend
metadata.json
task.md
tool_specifications.md
TOOLS.md
AGENTS.md
SOUL.md
FINAL_*.md
IMPLEMENTATION_*.md
MULTI_PROVIDER_IMPLEMENTATION.md
orchestrator.py
